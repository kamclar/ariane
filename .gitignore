*.py[cod]
*.so

# Virtual environments
venv/
.env
.env.*

# Jupyter
notebooks/
*.ipynb
.ipynb_checkpoints/

# Top-level text files (exclude root .txt files)
/*.txt



# Build, packaging
dist/
build/
*.egg-info/

# Logs and temp
*.log
*.sqlite3
/tmp/
/data/sources/
/data/precomputed/brca_exchange_*.tsv
/data/precomputed/brca_exchange_sample.json

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Railway/Nixpacks / deployment
.railway/
.nix/

# Node / other
node_modules/

# Ignore credentials and secrets
*.pem
*.key
secrets.yml

# Coverage
.coverage
htmlcov/

# Pytest
.pytest_cache/

# Optional: keep requirements.txt and scripts
!requirements.txt
!scripts/server-ops/

# Allow README and docs
!README.md
/docs/
!/docs/
/docs/*
!/docs/implementation_and_data_sources.md
